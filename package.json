{
  "name": "dashboard-ibn",
  "version": "0.1.0",
  "private": true,
  "description": "Dashboard interno de matrículas IBN — substitui Looker, lê Google Sheets via API com cache server-side.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check:sheets": "tsx --env-file=.env.local scripts/check-sheets.ts",
    "list:sheets": "tsx --env-file=.env.local scripts/list-sheets.ts",
    "analyze": "tsx --env-file=.env.local scripts/analyze.ts",
    "audit": "tsx --env-file=.env.local scripts/audit.ts",
    "ci": "pnpm run lint && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@auth/core": "^0.34.2",
    "@tremor/react": "^3.18.7",
    "googleapis": "^144.0.0",
    "next": "14.2.18",
    "next-auth": "5.0.0-beta.25",
    "nuqs": "^2.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.5",
    "clsx": "^2.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "axe-playwright": "^2.0.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^25.0.1",
    "msw": "^2.7.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.33.4"
}
