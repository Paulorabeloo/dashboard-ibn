# ============================================================================
# Dashboard IBN — variáveis de ambiente
# Copie este arquivo para `.env.local` e preencha com valores reais.
# Nunca commite `.env.local` ou qualquer arquivo com segredos reais.
# ============================================================================

# --- Auth.js v5 / Google OAuth -----------------------------------------------

# OAuth client (Google Cloud Console > APIs & Services > Credentials).
# Tipo: "Web application". Authorized redirect URI: ${AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Allowlist EXPLÍCITA de e-mails autorizados.
# CSV, case-insensitive. Fail-closed: vazio = ninguém entra.
# Validação no callback `signIn` do Auth.js + middleware (defesa em profundidade).
# Ex: AUTH_ALLOWED_EMAILS=gestor1@empresa.com,gestor2@empresa.com
AUTH_ALLOWED_EMAILS=

# Segredo para assinar cookies de sessão. Gerar com: openssl rand -base64 32
AUTH_SECRET=

# URL pública do app (dev: http://localhost:3000; produção: URL do Vercel).
AUTH_URL=http://localhost:3000

# --- Google Sheets API -------------------------------------------------------

# Service Account com escopo `spreadsheets.readonly` no projeto Google Cloud.
# Conteúdo do JSON da chave codificado em base64.
# Linux/Mac: base64 -i service-account.json | tr -d '\n'
# Windows PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json"))
GOOGLE_SA_KEY=

# ID da planilha (parte da URL entre /d/ e /edit).
SHEETS_ID=

# Range A1 da aba com os dados.
# Aspas internas em torno do nome (com espaços/acentos) são exigidas
# pelo Sheets API. Manter o `'...'!A:Y` literal entre aspas duplas.
SHEETS_RANGE="'Nome da Aba'!A:Y"

# --- Cache server-side -------------------------------------------------------

# TTL do cache de matrículas em segundos. Default 600 (10 min).
CACHE_TTL_SECONDS=600

# Bearer secret usado pelo Vercel Cron para autenticar /api/cron/revalidate.
# Gerar com: openssl rand -hex 32
CRON_SECRET=

# --- Observabilidade ---------------------------------------------------------

# DSN do Sentry. Opcional em dev, mandatório em produção.
SENTRY_DSN=

# Nível de log estruturado. Em prod usar "info". Em dev: "debug".
LOG_LEVEL=info
